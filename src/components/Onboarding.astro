<div id="onboarding-root" class="onboarding-overlay d-none">
    <div class="onboarding-glass-container">
        <!-- Step 1: The Gate -->
        <div id="step-gate" class="wizard-step active">
            <div class="text-center mb-5">
                <div class="brand-badge mb-3">MACADAM VAULT</div>
                <h1 class="display-5 fw-800 mb-3 gradient-text">Welcome to the Vault.</h1>
                <p class="lead text-muted px-4">Your data, your privacy, your hustle. Choose how you'd like to begin.</p>
            </div>

            <div class="gate-grid">
                <button class="gate-card group" id="btn-fresh">
                    <div class="gate-icon-box bg-rose-soft">
                        <i class="bi bi-rocket-takeoff"></i>
                    </div>
                    <div class="gate-card-body">
                        <h3 class="h5 fw-bold mb-1">New Workspace</h3>
                        <p class="small text-muted">Guided setup for your delivery business.</p>
                    </div>
                    <i class="bi bi-arrow-right ms-auto opacity-50 group-hover:opacity-100"></i>
                </button>

                <button class="gate-card group" id="btn-restore">
                    <div class="gate-icon-box bg-emerald-soft">
                        <i class="bi bi-cloud-upload"></i>
                    </div>
                    <div class="gate-card-body">
                        <h3 class="h5 fw-bold mb-1">Restore Vault</h3>
                        <p class="small text-muted">Import a .json backup from another device.</p>
                    </div>
                    <i class="bi bi-arrow-right ms-auto opacity-50 group-hover:opacity-100"></i>
                    <input type="file" id="restore-file" class="d-none" accept=".json">
                </button>

                <button class="gate-card group" id="btn-demo">
                    <div class="gate-icon-box bg-blue-soft">
                        <i class="bi bi-play-circle"></i>
                    </div>
                    <div class="gate-card-body">
                        <h3 class="h5 fw-bold mb-1">Explore Demo</h3>
                        <p class="small text-muted">See sample data for 8 historical weeks.</p>
                    </div>
                    <i class="bi bi-arrow-right ms-auto opacity-50 group-hover:opacity-100"></i>
                </button>
            </div>
        </div>

        <!-- Step 1.5: Platform Selection -->
        <div id="step-platforms" class="wizard-step">
            <div class="wizard-header mb-4">
                <h2 class="h3 fw-bold">Which platforms do you use?</h2>
                <p class="text-muted">Select all that apply. We'll tailor the app to your specific terminology.</p>
            </div>
            <div class="platform-grid mb-5">
                <button class="platform-card" data-platform="doordash">
                    <div class="platform-logo-box bg-doordash">
                        <i class="bi bi-dash-circle-fill"></i>
                    </div>
                    <span>DoorDash</span>
                    <div class="selection-check"><i class="bi bi-check-circle-fill"></i></div>
                </button>
                <button class="platform-card" data-platform="ubereats">
                    <div class="platform-logo-box bg-ubereats">
                        <i class="bi bi-u-circle-fill"></i>
                    </div>
                    <span>Uber Eats</span>
                    <div class="selection-check"><i class="bi bi-check-circle-fill"></i></div>
                </button>
                <button class="platform-card" data-platform="foodora">
                    <div class="platform-logo-box bg-foodora">
                        <i class="bi bi-f-circle-fill"></i>
                    </div>
                    <span>Foodora</span>
                    <div class="selection-check"><i class="bi bi-check-circle-fill"></i></div>
                </button>
                <button class="platform-card" data-platform="skip">
                    <div class="platform-logo-box bg-skip">
                        <i class="bi bi-s-circle-fill"></i>
                    </div>
                    <span>SkipTheDishes</span>
                    <div class="selection-check"><i class="bi bi-check-circle-fill"></i></div>
                </button>
                <button class="platform-card" data-platform="instacart">
                    <div class="platform-logo-box bg-instacart">
                        <i class="bi bi-basket-fill"></i>
                    </div>
                    <span>Instacart</span>
                    <div class="selection-check"><i class="bi bi-check-circle-fill"></i></div>
                </button>
                <button class="platform-card" data-platform="amazon">
                    <div class="platform-logo-box bg-amazon">
                        <i class="bi bi-box-fill"></i>
                    </div>
                    <span>Amazon Flex</span>
                    <div class="selection-check"><i class="bi bi-check-circle-fill"></i></div>
                </button>
                <button class="platform-card" data-platform="other">
                    <div class="platform-logo-box bg-other">
                        <i class="bi bi-plus-circle-fill"></i>
                    </div>
                    <span>Other</span>
                    <div class="selection-check"><i class="bi bi-check-circle-fill"></i></div>
                </button>
            </div>
            <div class="d-flex gap-3">
                <button class="btn btn-outline-secondary btn-lg px-4" data-back="gate">Back</button>
                <button class="btn btn-primary btn-lg flex-grow-1 py-3" id="btn-next-to-identity" disabled>Continue <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <!-- Step 2: Identity & Preferences -->
        <div id="step-identity" class="wizard-step">
            <div class="wizard-header mb-4">
                <h2 class="h3 fw-bold">Who's driving today?</h2>
                <p class="text-muted">Personalize your workspace and regional settings.</p>
            </div>
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold text-muted small uppercase">Your Name</label>
                    <input type="text" id="user-name" class="form-control form-control-lg custom-input" placeholder="e.g. Alex">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small uppercase">Region</label>
                    <select id="user-region" class="form-select form-control-lg custom-input">
                        <option value="CA">Canada</option>
                        <option value="US">USA</option>
                        <option value="UK">UK</option>
                        <option value="AU">Australia</option>
                        <option value="EU">Europe</option>
                    </select>
                    <p id="region-note" class="small text-warning mt-1 fw-bold"><i class="bi bi-info-circle me-1"></i> Note: In Canada, all tips are taxable income.</p>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small uppercase">Currency</label>
                    <input type="text" id="user-currency" class="form-control form-control-lg custom-input" value="$" maxlength="3">
                </div>
            </div>
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small uppercase">Decimal Separator</label>
                    <select id="user-decimal" class="form-select form-control-lg custom-input">
                        <option value=".">Dot (.)</option>
                        <option value=",">Comma (,)</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small uppercase">Number Format</label>
                    <select id="user-numformat" class="form-select form-control-lg custom-input">
                        <option value="1,234.56">1,234.56</option>
                        <option value="1.234,56">1.234,56</option>
                        <option value="1 234,56">1 234,56</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold text-muted small uppercase">Distance Unit</label>
                    <div class="btn-group w-100 shadow-sm" role="group">
                        <input type="radio" class="btn-check" name="dist-unit" id="unit-km" value="km" checked>
                        <label class="btn btn-outline-secondary py-2" for="unit-km">Kilometers (km)</label>
                        <input type="radio" class="btn-check" name="dist-unit" id="unit-mi" value="mi">
                        <label class="btn btn-outline-secondary py-2" for="unit-mi">Miles (mi)</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold text-muted small uppercase">Choose an Avatar</label>
                    <div class="avatar-grid mb-3">
                        <button class="avatar-btn active" data-avatar="😎">😎</button>
                        <button class="avatar-btn" data-avatar="🚗">🚗</button>
                        <button class="avatar-btn" data-avatar="🛵">🛵</button>
                        <button class="avatar-btn" data-avatar="🚴">🚴</button>
                        <button class="avatar-btn" data-avatar="📦">📦</button>
                        <button class="avatar-btn" data-avatar="⚡">⚡</button>
                        <button class="avatar-btn" data-avatar="💼">💼</button>
                        <button class="avatar-btn" data-avatar="🍕">🍕</button>
                        <button class="avatar-btn" data-avatar="🍔">🍔</button>
                        <button class="avatar-btn" data-avatar="🚛">🚛</button>
                        <button class="avatar-btn" data-avatar="🚲">🚲</button>
                        <button class="avatar-btn" data-avatar="🏎️">🏎️</button>
                    </div>
                    <div class="text-center">
                        <label for="avatar-upload" class="btn btn-sm btn-outline-secondary rounded-pill px-4">
                            <i class="bi bi-cloud-upload me-2"></i> Custom Upload
                        </label>
                        <input type="file" id="avatar-upload" class="d-none" accept="image/*">
                    </div>
                </div>
            </div>
            <div class="d-flex gap-3">
                <button class="btn btn-outline-secondary btn-lg px-4" data-back="platforms">Back</button>
                <button class="btn btn-primary btn-lg flex-grow-1 py-3" data-next="vehicle">Next Step <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <!-- Step 3: Vehicle Setup Wizard -->
        <div id="step-vehicle" class="wizard-step">
            <div class="wizard-header mb-4">
                <h2 class="h3 fw-bold">Setup your fleet</h2>
                <p class="text-muted">You can add multiple vehicles. We'll use these for expense calculations.</p>
            </div>
            
            <div id="vehicle-form-container" class="mb-4 p-4 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10">
                <div class="row g-3 mb-4">
                    <div class="col-4 col-md-2">
                        <button class="select-btn active py-2" data-vehicle="gas">
                            <i class="bi bi-car-front d-block mb-1 fs-4"></i>
                            <span class="small">Gas</span>
                        </button>
                    </div>
                    <div class="col-4 col-md-2">
                        <button class="select-btn py-2" data-vehicle="hybrid">
                            <i class="bi bi-ev-front d-block mb-1 fs-4"></i>
                            <span class="small">Hybrid</span>
                        </button>
                    </div>
                    <div class="col-4 col-md-2">
                        <button class="select-btn py-2" data-vehicle="ev">
                            <i class="bi bi-lightning-charge d-block mb-1 fs-4"></i>
                            <span class="small">EV</span>
                        </button>
                    </div>
                    <div class="col-4 col-md-2">
                        <button class="select-btn py-2" data-vehicle="bike">
                            <i class="bi bi-bicycle d-block mb-1 fs-4"></i>
                            <span class="small">Bike</span>
                        </button>
                    </div>
                    <div class="col-4 col-md-2">
                        <button class="select-btn py-2" data-vehicle="scooter">
                            <i class="bi bi-scooter d-block mb-1 fs-4"></i>
                            <span class="small">Scooter</span>
                        </button>
                    </div>
                    <div class="col-4 col-md-2">
                        <button class="select-btn py-2" data-vehicle="foot">
                            <i class="bi bi-person-walking d-block mb-1 fs-4"></i>
                            <span class="small">Foot</span>
                        </button>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small uppercase">Vehicle Nickname</label>
                        <input type="text" id="v-name" class="form-control custom-input" placeholder="e.g. My Civic">
                    </div>
                    <div class="col-md-6" id="group-efficiency">
                        <label class="form-label fw-bold text-muted small uppercase" id="lbl-efficiency">Efficiency</label>
                        <div class="input-group-custom">
                            <input type="number" id="v-efficiency" class="form-control custom-input" placeholder="0.0">
                            <span class="input-unit" id="unit-efficiency">L/100km</span>
                        </div>
                    </div>
                    <div class="col-md-6 group-fuel">
                        <label class="form-label fw-bold text-muted small uppercase">Fuel Price (per L/Gal)</label>
                        <div class="input-group-custom">
                            <span class="input-prefix">$</span>
                            <input type="number" id="v-fuel-price" class="form-control custom-input" placeholder="1.50">
                        </div>
                    </div>
                    <div class="col-md-6 group-fuel">
                        <label class="form-label fw-bold text-muted small uppercase">Engine Displacement (cc/L)</label>
                        <input type="text" id="v-engine" class="form-control custom-input" placeholder="2.0L">
                    </div>
                    <div class="col-md-6 d-none" id="group-ev">
                        <label class="form-label fw-bold text-muted small uppercase">Electricity Rate (per kWh)</label>
                        <div class="input-group-custom">
                            <span class="input-prefix">$</span>
                            <input type="number" id="v-elec-rate" class="form-control custom-input" placeholder="0.12">
                        </div>
                    </div>
                    <div class="col-md-6 d-none" id="group-bike">
                        <label class="form-label fw-bold text-muted small uppercase">Maint. Cost per km/mi</label>
                        <div class="input-group-custom">
                            <span class="input-prefix">$</span>
                            <input type="number" id="v-maint-cost" class="form-control custom-input" placeholder="0.05">
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button class="btn btn-outline-primary w-100 fw-bold" id="btn-add-vehicle">
                        <i class="bi bi-plus-circle me-2"></i> Add Vehicle to Profile
                    </button>
                </div>
            </div>

            <div id="vehicle-list" class="mb-5 d-flex flex-wrap gap-2">
                <!-- Added vehicles appear here -->
            </div>

            <div class="d-flex gap-3">
                <button class="btn btn-outline-secondary btn-lg px-4" data-back="identity">Back</button>
                <button class="btn btn-primary btn-lg flex-grow-1 py-3" id="btn-next-to-categories" disabled>Continue <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <!-- Step 4: Expense Categories -->
        <div id="step-categories" class="wizard-step">
            <div class="wizard-header mb-4">
                <h2 class="h3 fw-bold">Expense Categories</h2>
                <p class="text-muted">We've pre-filled some common categories. Tap to remove any you don't need.</p>
            </div>
            <div id="category-chips" class="category-grid mb-5">
                <!-- Dynamically filled -->
            </div>
            <div class="d-flex gap-3">
                <button class="btn btn-outline-secondary btn-lg px-4" data-back="vehicle">Back</button>
                <button class="btn btn-primary btn-lg flex-grow-1 py-3" data-next="preferences">Next Step <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <!-- Step 5: Work Schedule & Tax Config -->
        <div id="step-preferences" class="wizard-step">
            <div class="wizard-header mb-4">
                <h2 class="h3 fw-bold">Work Preferences</h2>
                <p class="text-muted">Tailor the dashboard to your routine.</p>
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold text-muted small uppercase">Schedule Intensity</label>
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <button class="select-btn active" data-intensity="full">
                            <span>Full-Time</span>
                        </button>
                    </div>
                    <div class="col-6 col-md-3">
                        <button class="select-btn" data-intensity="part">
                            <span>Part-Time</span>
                        </button>
                    </div>
                    <div class="col-6 col-md-3">
                        <button class="select-btn" data-intensity="side">
                            <span>Side Hustle</span>
                        </button>
                    </div>
                    <div class="col-6 col-md-3">
                        <button class="select-btn" data-intensity="seasonal">
                            <span>Seasonal</span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold text-muted small uppercase">Starting Zone / Home Base</label>
                <input type="text" id="user-zone" class="form-control form-control-lg custom-input" placeholder="e.g. Downtown, North End">
                <p class="small text-muted mt-2">Used for zone-based analytics and estimating dead miles.</p>
            </div>
            <div class="mb-5">
                <div class="form-check form-switch custom-switch">
                    <input class="form-check-input" type="checkbox" id="tax-registered">
                    <label class="form-check-label fw-bold" for="tax-registered">I am HST/GST Registered (Canada)</label>
                </div>
                <p class="small text-muted mt-2">Required if you earn >$30,000/year. This unlocks HST/ITC tracking.</p>
            </div>
            <div class="d-flex gap-3">
                <button class="btn btn-outline-secondary btn-lg px-4" data-back="categories">Back</button>
                <button class="btn btn-primary btn-lg flex-grow-1 py-3" data-next="goals">Next Step <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <!-- Step 5: Financial Targets -->
        <div id="step-goals" class="wizard-step">
            <div class="wizard-header mb-4">
                <h2 class="h3 fw-bold">Financial Targets</h2>
                <p class="text-muted">Set goals to track your progress automatically.</p>
            </div>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small uppercase">Weekly Goal</label>
                    <div class="input-group-custom">
                        <span class="input-prefix">$</span>
                        <input type="number" id="user-goal-weekly" class="form-control form-control-lg custom-input" placeholder="e.g. 800">
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small uppercase">Monthly Goal</label>
                    <div class="input-group-custom">
                        <span class="input-prefix">$</span>
                        <input type="number" id="user-goal-monthly" class="form-control form-control-lg custom-input" placeholder="e.g. 3500">
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small uppercase">Annual Goal</label>
                    <div class="input-group-custom">
                        <span class="input-prefix">$</span>
                        <input type="number" id="user-goal-annual" class="form-control form-control-lg custom-input" placeholder="e.g. 40000">
                    </div>
                </div>
            </div>
            <div class="mb-5">
                <label class="form-label fw-bold text-muted small uppercase">Tax Withholding Goal (%)</label>
                <div class="input-group-custom">
                    <input type="number" id="user-tax" class="form-control form-control-lg custom-input" value="25">
                    <span class="input-unit">%</span>
                </div>
                <p class="small text-muted mt-2">Recommended: 20-30% for independent delivery partners.</p>
            </div>
            <div class="d-flex gap-3">
                <button class="btn btn-outline-secondary btn-lg px-4" data-back="preferences">Back</button>
                <button class="btn btn-primary btn-lg flex-grow-1 py-3" data-next="theme">Next Step <i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <!-- Step 7: Appearance & Notifications -->
        <div id="step-theme" class="wizard-step">
            <div class="wizard-header mb-4">
                <h2 class="h3 fw-bold">Final Touches</h2>
                <p class="text-muted">Choose your theme and notification settings.</p>
            </div>
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold text-muted small uppercase">Visual Theme</label>
                    <div class="btn-group w-100 shadow-sm" role="group">
                        <input type="radio" class="btn-check" name="theme-pref" id="theme-light" value="light">
                        <label class="btn btn-outline-secondary py-3" for="theme-light"><i class="bi bi-sun"></i> Light</label>
                        <input type="radio" class="btn-check" name="theme-pref" id="theme-dark" value="dark" checked>
                        <label class="btn btn-outline-secondary py-3" for="theme-dark"><i class="bi bi-moon"></i> Dark</label>
                        <input type="radio" class="btn-check" name="theme-pref" id="theme-auto" value="auto">
                        <label class="btn btn-outline-secondary py-3" for="theme-auto"><i class="bi bi-display"></i> Auto</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold text-muted small uppercase">Notifications</label>
                    <div class="form-check form-switch custom-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="notif-daily" checked>
                        <label class="form-check-label" for="notif-daily">Daily Summaries</label>
                    </div>
                    <div class="form-check form-switch custom-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="notif-goals" checked>
                        <label class="form-check-label" for="notif-goals">Goal Nudges</label>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-3">
                <button class="btn btn-outline-secondary btn-lg px-4" data-back="goals">Back</button>
                <button class="btn btn-success btn-lg flex-grow-1 py-3 shadow-lg fw-bold" id="btn-finish">Initialize Vault <i class="bi bi-safe-fill ms-2"></i></button>
            </div>
        </div>

        <!-- Step 6: Success -->
        <div id="step-success" class="wizard-step text-center">
            <div class="success-icon-container mb-4">
                <div class="success-circle">
                    <i class="bi bi-check-lg"></i>
                </div>
                <canvas id="confetti-canvas" class="confetti-canvas"></canvas>
            </div>
            <h2 class="h1 fw-800 mb-3 gradient-text" id="success-message">You're all set!</h2>
            <p class="lead text-muted mb-5">Your local vault is encrypted and ready for action. Let's start tracking your hustle.</p>
            <button class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold" id="btn-enter-vault">Enter the Vault <i class="bi bi-door-open-fill ms-2"></i></button>
        </div>

        <!-- Loader -->
        <div id="wizard-loader" class="wizard-loader d-none">
            <div class="loader-content">
                <div class="spinner-border text-primary" role="status"></div>
                <p id="loader-text" class="mt-3 fw-medium text-white">Initializing your local vault...</p>
            </div>
        </div>
    </div>
</div>

<style>
    .onboarding-overlay { 
        position: fixed; 
        inset: 0; 
        background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%); 
        z-index: 10000; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        padding: 2rem; 
        overflow-y: auto; 
    }
    
    .onboarding-glass-container { 
        max-width: 720px; 
        width: 100%; 
        background: rgba(30, 41, 59, 0.75); 
        backdrop-filter: blur(40px); 
        border: 1px solid rgba(255, 255, 255, 0.1); 
        border-radius: 3rem; 
        padding: 3.5rem; 
        box-shadow: 0 40px 100px -20px rgba(0,0,0,0.8); 
        position: relative; 
    }

    .gradient-text { 
        background: linear-gradient(135deg, #fff, #94a3b8); 
        -webkit-background-clip: text; 
        -webkit-text-fill-color: transparent; 
        font-weight: 800; 
    }

    .brand-badge { 
        display: inline-block; 
        padding: 0.5rem 1.25rem; 
        background: rgba(99, 102, 241, 0.2); 
        color: #a5b4fc; 
        border-radius: 100px; 
        font-size: 0.7rem; 
        font-weight: 900; 
        letter-spacing: 0.2em; 
        border: 1px solid rgba(129, 140, 248, 0.3); 
    }
    
    .wizard-step { display: none; }
