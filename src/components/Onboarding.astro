        .onboarding-glass-container { padding: 2rem; border-radius: 2rem; }
        .avatar-grid { grid-template-columns: repeat(4, 1fr); }
        .gate-card { padding: 1.25rem; }
    }
</style>

<script>
    import { db } from '../lib/db';
    import { seedDemoData } from '../lib/demo';

    function init() {
        const root = document.getElementById('onboarding-root');
        const isOnboarded = localStorage.getItem('macadam_onboarded') || sessionStorage.getItem('macadam_onboarded');
        if (!isOnboarded) {
            root?.classList.remove('d-none');
        }

        // Nav Logic
        document.querySelectorAll('[data-next]').forEach(btn => {
            btn.addEventListener('click', () => {
                const stepId = (btn as HTMLElement).dataset.next;
                showStep(stepId!);
            });
        });

        document.querySelectorAll('[data-back]').forEach(btn => {
            btn.addEventListener('click', () => {
                const stepId = (btn as HTMLElement).dataset.back;
                showStep(stepId!);
            });
        });

        // Selection Logic
        bindSelection('.avatar-btn');
        bindSelection('.select-btn[data-vehicle]', (val) => {
            const grpEfficiency = document.getElementById('group-efficiency');
            const grpFuel = document.querySelectorAll('.group-fuel');
            const grpEv = document.getElementById('group-ev');
            const grpBike = document.getElementById('group-bike');
            const lblEfficiency = document.getElementById('lbl-efficiency');
            const unitEfficiency = document.getElementById('unit-efficiency');
            const distUnit = (document.querySelector('input[name="dist-unit"]:checked') as HTMLInputElement).value;

            // Reset
            grpEfficiency?.classList.remove('d-none');
            grpFuel.forEach(g => g.classList.remove('d-none'));
            grpEv?.classList.add('d-none');
            grpBike?.classList.add('d-none');

            if (val === 'gas' || val === 'hybrid') {
                if (lblEfficiency) lblEfficiency.textContent = 'Fuel Efficiency';
                if (unitEfficiency) unitEfficiency.textContent = distUnit === 'km' ? 'L/100km' : 'MPG';
            } else if (val === 'ev') {
                if (lblEfficiency) lblEfficiency.textContent = 'Electricity Usage';
                if (unitEfficiency) unitEfficiency.textContent = 'kWh/100km';
                grpFuel.forEach(g => g.classList.add('d-none'));
                grpEv?.classList.remove('d-none');
            } else if (val === 'bike' || val === 'scooter') {
                grpEfficiency?.classList.add('d-none');
                grpFuel.forEach(g => g.classList.add('d-none'));
                grpBike?.classList.remove('d-none');
            } else if (val === 'foot') {
                grpEfficiency?.classList.add('d-none');
                grpFuel.forEach(g => g.classList.add('d-none'));
            }
            updateCategoryChips(val);
        });
        bindSelection('.select-btn[data-intensity]');

        // Multiple Vehicle Logic
        const addedVehicles: any[] = [];
        const btnAddVehicle = document.getElementById('btn-add-vehicle');
        const vehicleList = document.getElementById('vehicle-list');
        const nextToCategoriesBtn = document.getElementById('btn-next-to-categories') as HTMLButtonElement;

        btnAddVehicle?.addEventListener('click', () => {
            const type = (document.querySelector('.select-btn.active[data-vehicle]') as HTMLElement).dataset.vehicle;
            const name = (document.getElementById('v-name') as HTMLInputElement).value || `My ${type}`;
            const efficiency = parseFloat((document.getElementById('v-efficiency') as HTMLInputElement).value || '0');
            const fuelPrice = parseFloat((document.getElementById('v-fuel-price') as HTMLInputElement).value || '0');
            const engine = (document.getElementById('v-engine') as HTMLInputElement).value;
            const elecRate = parseFloat((document.getElementById('v-elec-rate') as HTMLInputElement).value || '0');
            const maintCost = parseFloat((document.getElementById('v-maint-cost') as HTMLInputElement).value || '0');
            
            const v = {
                name,
                type,
                efficiency,
                fuelPrice,
                engine,
                elecRate,
                maintCost,
                isDefault: addedVehicles.length === 0
            };

            addedVehicles.push(v);
            renderVehicleList();
            
            // Clear inputs
            (document.getElementById('v-name') as HTMLInputElement).value = '';
            (document.getElementById('v-efficiency') as HTMLInputElement).value = '';
            
            nextToCategoriesBtn.disabled = addedVehicles.length === 0;
            saveProgress('vehicle', { vehicles: addedVehicles });
        });

        function renderVehicleList() {
            if (!vehicleList) return;
            vehicleList.innerHTML = addedVehicles.map((v, i) => `
                <div class="category-chip" style="background: rgba(99, 102, 241, 0.2); border-color: #6366f1;">
                    <span>${v.name} (${v.type})</span>
                    <i class="bi bi-x-circle-fill" onclick="window.removeVehicle(${i})"></i>
                </div>
            `).join('');
        }

        (window as any).removeVehicle = (index: number) => {
            addedVehicles.splice(index, 1);
            renderVehicleList();
            nextToCategoriesBtn.disabled = addedVehicles.length === 0;
        };

        nextToCategoriesBtn?.addEventListener('click', () => {
            showStep('categories');
            saveProgress('categories');
        });

        // Avatar Upload Logic
        const avatarUpload = document.getElementById('avatar-upload') as HTMLInputElement;
        avatarUpload?.addEventListener('change', (e) => {
            const file = (e.target as HTMLInputElement).files?.[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = (event) => {
                const base64 = event.target?.result as string;
                // Add to avatar grid temporarily or just select it
                const customBtn = document.createElement('button');
                customBtn.className = 'avatar-btn active';
                customBtn.dataset.avatar = base64;
                customBtn.innerHTML = `<img src="${base64}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">`;
                
                document.querySelectorAll('.avatar-btn').forEach(b => b.classList.remove('active'));
                document.querySelector('.avatar-grid')?.appendChild(customBtn);
                
                customBtn.addEventListener('click', () => {
                    document.querySelectorAll('.avatar-btn').forEach(b => b.classList.remove('active'));
                    customBtn.classList.add('active');
                });
            };
            reader.readAsDataURL(file);
        });

        // Region Logic (CAD Tips Note)
        const regionSelect = document.getElementById('user-region') as HTMLSelectElement;
        regionSelect?.addEventListener('change', () => {
            const note = document.getElementById('region-note');
            if (regionSelect.value === 'CA') {
                if (note) note.classList.remove('d-none');
            } else {
                if (note) note.classList.add('d-none');
            }
        });

        // Initialize categories for default 'gas'
        updateCategoryChips('gas');

        // Actions
        document.getElementById('btn-fresh')?.addEventListener('click', () => {
            saveProgress('platforms');
            showStep('platforms');
        });

        // Platform Selection Logic
        const platformCards = document.querySelectorAll('.platform-card');
        const nextToIdentityBtn = document.getElementById('btn-next-to-identity') as HTMLButtonElement;
        const selectedPlatforms = new Set<string>();

        platformCards.forEach(card => {
            card.addEventListener('click', () => {
                const platform = (card as HTMLElement).dataset.platform!;
                if (selectedPlatforms.has(platform)) {
                    selectedPlatforms.delete(platform);
                    card.classList.remove('selected');
                } else {
                    selectedPlatforms.add(platform);
                    card.classList.add('selected');
                }
                nextToIdentityBtn.disabled = selectedPlatforms.size === 0;
                saveProgress('platforms', { platforms: Array.from(selectedPlatforms) });
            });
        });

        nextToIdentityBtn?.addEventListener('click', () => {
            showStep('identity');
            saveProgress('identity');
        });
        
        document.getElementById('btn-demo')?.addEventListener('click', async () => {
            showLoader('Generating sample data...');
            await seedDemoData();
            // Using sessionStorage makes this session transient
            sessionStorage.setItem('macadam_onboarded', 'true');
            sessionStorage.setItem('macadam_demo_mode', 'true');
            window.location.reload();
        });

        document.getElementById('btn-restore')?.addEventListener('click', () => {
            document.getElementById('restore-file')?.click();
        });

        document.getElementById('restore-file')?.addEventListener('change', async (e) => {
            const file = (e.target as HTMLInputElement).files?.[0];
            if (!file) return;
            
            showLoader('Restoring your vault...');
            const reader = new FileReader();
            reader.onload = async (event) => {
                try {
                    const parsed = JSON.parse(event.target?.result as string);
                    if (parsed.app !== 'Macadam' || !parsed.data) throw new Error('Invalid backup file.');

                    // Clear and restore
                    await db.weekly_earnings.clear();
                    await db.expenses.clear();
                    await db.expense_categories.clear();
                    await db.settings.clear();

                    if (parsed.data.weekly_earnings) await db.weekly_earnings.bulkAdd(parsed.data.weekly_earnings);
                    if (parsed.data.expenses) await db.expenses.bulkAdd(parsed.data.expenses);
                    if (parsed.data.expense_categories) await db.expense_categories.bulkAdd(parsed.data.expense_categories);
                    if (parsed.data.settings) await db.settings.bulkAdd(parsed.data.settings);

                    localStorage.setItem('macadam_onboarded', 'true');
                    window.location.reload();
                } catch (err) {
                    window.MacadamNotify.show('Restore failed: ' + (err as Error).message, 'danger');
                    hideLoader();
                }
            };
            reader.readAsText(file);
        });

        document.getElementById('btn-finish')?.addEventListener('click', async () => {
            const name = (document.getElementById('user-name') as HTMLInputElement).value;
            if (!name) return window.MacadamNotify.show('Please enter your name.', 'warning');
            
            showLoader('Initializing your vault...');

            const vehicle = (document.querySelector('.select-btn.active[data-vehicle]') as HTMLElement)?.dataset.vehicle;
            const intensity = (document.querySelector('.select-btn.active[data-intensity]') as HTMLElement)?.dataset.intensity;
            const distUnit = (document.querySelector('input[name="dist-unit"]:checked') as HTMLInputElement).value;
            const theme = (document.querySelector('input[name="theme-pref"]:checked') as HTMLInputElement).value;

            const settings = {
                user_name: name,
                avatar: (document.querySelector('.avatar-btn.active') as HTMLElement)?.dataset.avatar || '😎',
                region: (document.getElementById('user-region') as HTMLSelectElement).value,
                currency: (document.getElementById('user-currency') as HTMLInputElement).value || '$',
                decimal_separator: (document.getElementById('user-decimal') as HTMLSelectElement).value,
                number_format: (document.getElementById('user-numformat') as HTMLSelectElement).value,
                distance_unit: distUnit,
                vehicle_type: vehicle,
                work_intensity: intensity,
                starting_zone: (document.getElementById('user-zone') as HTMLInputElement).value,
                hst_registered: (document.getElementById('tax-registered') as HTMLInputElement).checked,
                goal_weekly: (document.getElementById('user-goal-weekly') as HTMLInputElement).value,
                goal_monthly: (document.getElementById('user-goal-monthly') as HTMLInputElement).value,
                goal_annual: (document.getElementById('user-goal-annual') as HTMLInputElement).value,
                tax_percent: (document.getElementById('user-tax') as HTMLInputElement).value,
                theme: theme,
                notif_daily: (document.getElementById('notif-daily') as HTMLInputElement).checked,
                notif_goals: (document.getElementById('notif-goals') as HTMLInputElement).checked,
                platforms: Array.from(selectedPlatforms)
            };

            // Save platforms to DB
            const platformConfigs: any = {
                doordash: { name: 'DoorDash', color: '#FF3008', terminology: { driver: 'Dasher', task: 'order' } },
                ubereats: { name: 'Uber Eats', color: '#142328', terminology: { driver: 'Courier', task: 'trip' } },
                foodora: { name: 'Foodora', color: '#E2006A', terminology: { driver: 'Rider', task: 'delivery' } },
                skip: { name: 'SkipTheDishes', color: '#F96302', terminology: { driver: 'Courier', task: 'order' } },
                instacart: { name: 'Instacart', color: '#43B02A', terminology: { driver: 'Shopper', task: 'batch' } },
                amazon: { name: 'Amazon Flex', color: '#FF9900', terminology: { driver: 'Driver', task: 'block' } },
                other: { name: 'Other', color: '#64748b', terminology: { driver: 'Driver', task: 'delivery' } }
            };

            for (const pid of selectedPlatforms) {
                const config = platformConfigs[pid] || platformConfigs.other;
                await db.platforms.put({
                    id: pid,
                    name: config.name,
                    color: config.color,
                    logo: pid,
                    terminology: config.terminology,
                    active: 1
                });
            }

            // Save vehicles to DB
            for (const v of addedVehicles) {
                await db.vehicles.put({
                    name: v.name,
                    type: v.type,
                    efficiency: v.efficiency,
                    efficiencyUnit: v.type === 'ev' ? 'kWh/100km' : (distUnit === 'km' ? 'L/100km' : 'MPG'),
                    fuelPrice: v.fuelPrice,
                    engineDisplacement: v.engine,
                    electricityRate: v.elecRate,
                    maintenanceCostPerKm: v.maintCost,
                    isDefault: v.isDefault
                });
            }

            // Save to DB and LocalStorage using helper
            for (const [key, value] of Object.entries(settings)) {
                await db.setSetting(`macadam_v2_${key}`, value);
            }

            // Apply theme immediately
            if (theme !== 'auto') {
                document.documentElement.setAttribute('data-bs-theme', theme);
            }

            // Save categories
            const chips = document.querySelectorAll('.category-chip span');
            const categories = Array.from(chips).map(c => ({ name: c.textContent! }));
            await db.expense_categories.clear();
            await db.expense_categories.bulkAdd(categories);

            localStorage.setItem('macadam_onboarded', 'true');
            sessionStorage.removeItem('macadam_onboarding_temp');
            
            // Item 18: Success animation and personalized message
            const successMsg = document.getElementById('success-message');
            if (successMsg) successMsg.textContent = `Your Vault is Ready, ${name}.`;

            // Show Success Step
            hideLoader();
            showStep('success');
            triggerConfetti();
        });

        document.getElementById('btn-enter-vault')?.addEventListener('click', () => {
            window.location.reload();
        });
    }

    let currentCategories = ['Fuel', 'Maintenance', 'Supplies', 'Insurance', 'Phone/Data', 'Taxes/Fees'];

    function updateCategoryChips(vehicle: string) {
        if (vehicle === 'bike') {
            currentCategories = ['Maintenance', 'Supplies', 'Safety Gear', 'Phone/Data'];
        } else if (vehicle === 'ev') {
            currentCategories = ['Charging', 'Maintenance', 'Supplies', 'Insurance', 'Phone/Data'];
        } else {
            currentCategories = ['Fuel', 'Maintenance', 'Supplies', 'Insurance', 'Phone/Data', 'Taxes/Fees'];
        }
        renderCategories();
    }

    function renderCategories() {
        const container = document.getElementById('category-chips');
        if (!container) return;
        container.innerHTML = currentCategories.map(cat => `
            <div class="category-chip" onclick="this.remove()">
                <span>${cat}</span>
                <i class="bi bi-x-circle-fill"></i>
            </div>
        `).join('');
    }

    function showStep(id: string) {
        document.querySelectorAll('.wizard-step').forEach(s => s.classList.remove('active'));
        document.getElementById(`step-${id}`)?.classList.add('active');
    }

    function bindSelection(selector: string, callback?: (val: string) => void) {
        document.querySelectorAll(selector).forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll(selector).forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                if (callback) callback((btn as HTMLElement).dataset.avatar || (btn as HTMLElement).dataset.vehicle || '');
            });
        });
    }

    function triggerConfetti() {
        const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext('2d')!;
        canvas.width = 300;
        canvas.height = 300;

        const particles: any[] = [];
        for (let i = 0; i < 50; i++) {
            particles.push({
                x: 150,
                y: 150,
                vx: (Math.random() - 0.5) * 10,
                vy: (Math.random() - 0.5) * 10 - 5,
                color: ['#6366f1', '#f43f5e', '#10b981', '#f59e0b'][Math.floor(Math.random() * 4)],
                size: Math.random() * 5 + 5
            });
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.x += p.vx;
                p.y += p.vy;
                p.vy += 0.2;
                ctx.fillStyle = p.color;
                ctx.fillRect(p.x, p.y, p.size, p.size);
            });
            if (particles.some(p => p.y < canvas.height)) {
                requestAnimationFrame(animate);
            }
        }
        animate();
    }

    function showLoader(text: string) {
        const loader = document.getElementById('wizard-loader');
        const loaderText = document.getElementById('loader-text');
        if (loader && loaderText) {
            loaderText.textContent = text;
            loader.classList.remove('d-none');
        }
    }

    function hideLoader() {
        document.getElementById('wizard-loader')?.classList.add('d-none');
    }

    function saveProgress(step: string, data: any = {}) {
        const current = JSON.parse(sessionStorage.getItem('macadam_onboarding_temp') || '{}');
        sessionStorage.setItem('macadam_onboarding_temp', JSON.stringify({
            ...current,
            last_step: step,
            ...data
        }));
    }

    function loadProgress() {
        const temp = sessionStorage.getItem('macadam_onboarding_temp');
        if (!temp) return;

        const data = JSON.parse(temp);
        if (data.last_step) {
            // @ts-ignore
            const resumeModal = new bootstrap.Modal(document.getElementById('resumeModal'));
            resumeModal.show();

            document.getElementById('btn-resume-continue')?.addEventListener('click', () => {
                // Pre-fill fields
                if (data.platforms) {
                    data.platforms.forEach((p: string) => {
                        const card = document.querySelector(`[data-platform="${p}"]`);
                        card?.classList.add('selected');
                        selectedPlatforms.add(p);
                    });
                    const nextBtn = document.getElementById('btn-next-to-identity') as HTMLButtonElement;
                    if (nextBtn) nextBtn.disabled = false;
                }
                showStep(data.last_step);
                resumeModal.hide();
            });

            document.getElementById('btn-resume-reset')?.addEventListener('click', () => {
                sessionStorage.removeItem('macadam_onboarding_temp');
                resumeModal.hide();
                window.location.reload();
            });
        }
    }

    const selectedPlatforms = new Set<string>();

    document.addEventListener('astro:page-load', () => {
        init();
        loadProgress();
    });
</script>

