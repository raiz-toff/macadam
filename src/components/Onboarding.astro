    }
    .category-chip:hover { background: rgba(244, 63, 94, 0.2); border-color: #f43f5e; color: #fb7185; }
    .category-chip i { font-size: 0.8rem; opacity: 0.5; }

    .success-icon-container { position: relative; display: inline-block; }
    .success-circle { 
        width: 100px; 
        height: 100px; 
        background: #10b981; 
        color: #fff; 
        border-radius: 50%; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        font-size: 3rem; 
        box-shadow: 0 20px 40px rgba(16, 185, 129, 0.4); 
        animation: successPop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    }
    .confetti-canvas { position: absolute; inset: -100px; pointer-events: none; }

    @keyframes successPop {
