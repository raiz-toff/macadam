    .custom-switch .form-check-input { width: 3rem; height: 1.5rem; background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); }
    .custom-switch .form-check-input:checked { background-color: #6366f1; border-color: #6366f1; }
    .custom-switch .form-check-label { padding-top: 0.2rem; padding-left: 0.5rem; color: #94a3b8; }

